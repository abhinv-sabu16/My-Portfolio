# ===================================
# Portfolio Environment Variables
# ===================================

# ---- Notion Integration ----
# Get your API key from https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Notion databases IDs (from the URL of your database)
NOTION_PROJECTS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_BLOG_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- MongoDB (Optional - for contact form storage) ----
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB=portfolio

# ---- Email (Optional - for contact form notifications) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
EMAIL_TO=hello@yourportfolio.com

# ---- Site Config ----
NEXT_PUBLIC_SITE_URL=https://yourportfolio.com
